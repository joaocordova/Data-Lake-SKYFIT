# ============================================================================
# SKYFIT DATA LAKE - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# AZURE STORAGE (ADLS Gen2)
# ----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_KEY=your_storage_account_key
ADLS_CONTAINER=datalake

# ----------------------------------------------------------------------------
# POSTGRESQL
# ----------------------------------------------------------------------------
PG_HOST=your_server.postgres.database.azure.com
PG_PORT=5432
PG_DATABASE=your_database
PG_USER=your_username
PG_PASSWORD=your_password
PG_SSLMODE=require

# ----------------------------------------------------------------------------
# PIPEDRIVE API
# ----------------------------------------------------------------------------
# Get tokens from: Settings > Personal Preferences > API
PIPEDRIVE_COMPANY_DOMAIN=your_company

# Scope: comercial
PIPEDRIVE_TOKEN_COMERCIAL=your_api_token_comercial

# Scope: expansao
PIPEDRIVE_TOKEN_EXPANSAO=your_api_token_expansao

# ----------------------------------------------------------------------------
# ZENDESK API
# ----------------------------------------------------------------------------
# Get token from: Admin > Channels > API
ZENDESK_SUBDOMAIN=your_subdomain
ZENDESK_EMAIL=admin@yourcompany.com
ZENDESK_API_TOKEN=your_api_token

# ----------------------------------------------------------------------------
# EVO API (Future)
# ----------------------------------------------------------------------------
# EVO_API_URL=https://evo-integracao.w12app.com.br
# EVO_USERNAME=your_username
# EVO_PASSWORD=your_password

# ----------------------------------------------------------------------------
# OPTIONAL: Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
